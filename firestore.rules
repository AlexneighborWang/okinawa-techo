rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow all authenticated users to read and write to shared trip data
    // This is a family travel app, so we trust authenticated users for now.
    // In a production app, you would restrict this to specific family members.
    
    match /schedule/{itemId} {
      allow read, write: if isAuthenticated();
    }
    
    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated();
    }
    
    match /planning/{itemId} {
      allow read, write: if isAuthenticated();
    }
    
    match /hotels/{hotelId} {
      allow read, write: if isAuthenticated();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
